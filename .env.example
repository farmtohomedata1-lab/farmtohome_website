# Copy this file to .env and fill in real values from your Supabase project
# dashboard: Project Settings -> Database (connection string) and
# Project Settings -> API (URL + keys).

# Postgres connection string used by Prisma. Supabase's "Connection pooling"
# string (port 6543, pgbouncer) works fine here for both the app and
# `prisma migrate` in this setup.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[your anon/public key]"

# Project Settings -> API -> service_role key.
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_, never import in a "use client"
# file or expose in any client-side bundle or API response.
SUPABASE_SERVICE_ROLE_KEY="[your service_role key]"

# The email address(es) allowed to sign in to /admin (comma-separated for
# more than one). REQUIRED for admin access. SERVER-ONLY — never prefix with
# NEXT_PUBLIC_.
#
# Why this exists: admin and customer accounts share ONE Supabase Auth
# project (customers are created via admin.createUser in app/login), so being
# a valid Supabase user is NOT enough to be an admin. Without this allowlist,
# any customer could sign in at /admin/login with their own credentials and
# get full admin access. The app fails CLOSED — if this is empty/unset, NOBODY
# can access /admin (including the real admin), so this must be set in the
# Vercel Production environment before/with the deploy that introduces it, or
# the admin will be locked out. Use the exact email the admin logs in with.
ADMIN_EMAILS="owner@yourdomain.com"

# Resend (https://resend.com) — order confirmation + shop-owner alert
# emails. Optional: if RESEND_API_KEY is unset, order emails are skipped
# with a console warning rather than failing order placement.
RESEND_API_KEY="[your Resend API key]"
# Must be on a domain verified with Resend once you're past their sandbox
# sender (onboarding@resend.dev, which only delivers to your own account's
# email during testing).
ORDER_EMAIL_FROM="Farm To Home <orders@yourdomain.com>"
# Where new-order alert emails are sent (the shop owner's inbox).
ORDER_ALERT_EMAIL="owner@yourdomain.com"
# Where /contact form submissions are sent — deliberately separate from
# ORDER_ALERT_EMAIL above. Comma-separated, so more recipients can be added
# later without a code change.
CONTACT_NOTIFY_EMAILS="owner@yourdomain.com,manager@yourdomain.com"

# Stripe (https://dashboard.stripe.com/test/apikeys) — card payments at
# checkout. Use TEST mode keys (pk_test_/sk_test_) until you are genuinely
# ready to take real payments; switching to live keys (pk_live_/sk_live_)
# later is a pure env-var swap, zero code changes.
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_ or expose client-side.
# Optional in the sense that the app won't crash without it, but selecting
# "Card" at checkout will show a clear error until it's set.
# Use a RESTRICTED key (rk_test_/rk_live_), not the full secret key —
# Dashboard -> Developers -> API keys -> Create restricted key -> set
# "Payment Intents" to Write (this app never calls any other Stripe
# resource) and leave everything else at None. Limits the blast radius if
# this key is ever exposed again (it already has been, twice, this project).
STRIPE_SECRET_KEY="rk_test_[your Stripe restricted key]"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_[your Stripe publishable key]"
# Dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret
# (or `stripe listen` prints one for local testing). Used to verify every
# incoming webhook request is genuinely from Stripe before trusting it —
# never skip this check.
STRIPE_WEBHOOK_SECRET="whsec_[your webhook signing secret]"

# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile -> Add site,
# free) — second layer against scripted bot signups on /login, on top of the
# existing rate limiting. Optional in the sense that the app won't crash
# without it — the widget just doesn't render and no token is sent. Only the
# site key is needed here; the app never verifies the token itself.
NEXT_PUBLIC_TURNSTILE_SITE_KEY="[your Turnstile site key]"
# The secret key from that same Turnstile site goes into Supabase Dashboard
# -> Authentication -> Attack Protection -> Enable CAPTCHA protection, NOT
# into this app's env — Supabase verifies the token server-side using it.
# Enable it there LAST, only after NEXT_PUBLIC_TURNSTILE_SITE_KEY above is
# live and deployed: flipping it on in Supabase first would reject every
# real login/signup, since no page would be sending a token yet.

# Sentry (https://sentry.io -> Create account -> Create project -> select
# "Next.js") — real production error tracking, so a bug shows up here
# instead of only from a customer's screenshot. The free "Developer" plan
# (5k errors/month) is enough for this site's scale.
# Optional in the sense that the app won't crash without it — Sentry.init
# with an undefined DSN disables itself silently, same graceful-degradation
# pattern as Stripe/Turnstile above. Prefixed NEXT_PUBLIC_ because the
# browser-side SDK (instrumentation-client.ts) needs to read it too; a
# Sentry DSN is meant to be public (it can only submit events, not read
# anything back) so this is safe to expose client-side, unlike every other
# _PUBLIC_ vs. server-only distinction elsewhere in this file.
# Project Settings -> Client Keys (DSN) once the project exists.
NEXT_PUBLIC_SENTRY_DSN="https://[your-key]@[your-org].ingest.sentry.io/[project-id]"
# Deliberately NOT using SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT here
# — this integration is intentionally kept to error capture only (no source
# map upload, no performance tracing, no session replay), which is what
# next.config.ts's sourcemaps: { disable: true } enforces regardless of
# whether those get added later. Add them only if you want readable
# (unminified) stack traces in the Sentry dashboard — not required for
# alerts to work.
