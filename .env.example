# Copy this file to .env and fill in real values from your Supabase project
# dashboard: Project Settings -> Database (connection string) and
# Project Settings -> API (URL + keys).

# Postgres connection string used by Prisma. Supabase's "Connection pooling"
# string (port 6543, pgbouncer) works fine here for both the app and
# `prisma migrate` in this setup.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[your anon/public key]"

# Project Settings -> API -> service_role key.
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_, never import in a "use client"
# file or expose in any client-side bundle or API response.
SUPABASE_SERVICE_ROLE_KEY="[your service_role key]"

# Resend (https://resend.com) — order confirmation + shop-owner alert
# emails. Optional: if RESEND_API_KEY is unset, order emails are skipped
# with a console warning rather than failing order placement.
RESEND_API_KEY="[your Resend API key]"
# Must be on a domain verified with Resend once you're past their sandbox
# sender (onboarding@resend.dev, which only delivers to your own account's
# email during testing).
ORDER_EMAIL_FROM="Farm To Home <orders@yourdomain.com>"
# Where new-order alert emails are sent (the shop owner's inbox).
ORDER_ALERT_EMAIL="owner@yourdomain.com"
